{
  "name": "dtxmania-web",
  "version": "0.0.0",
  "private": true,
  "description": "DTXmaniaNX WebXR rewrite (TypeScript)",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:high": "pnpm audit --audit-level=high",
    "prepare": "git -C .. config --local core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "22.11.0",
    "pnpm": "9.15.0"
  },
  "packageManager": "pnpm@9.15.0"
}
